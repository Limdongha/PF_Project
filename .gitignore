# ── OS 생성 파일 ──
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ── 에디터 / IDE ──
.vscode/
.idea/
*.swp
*~

# ── Python 캐시 (tools/gen_art.py 실행 시 생김) ──
__pycache__/
*.pyc

# ── 대용량 "원본" 영상 (압축 전 raw 파일은 커밋 금지) ──
# 주의: 사이트에 실제로 쓰는 압축본(assets/img/hero.mp4, hero.webm 등)은
#       커밋해야 함! 아래는 편집용 원본 포맷만 제외.
*.mov
*.avi
*.mkv
*.prproj

# ── 쇼케이스 원본 원고(_src) — 로컬 전용, 공개 레포에 올리지 않음 ──
# 노션 PDF·내부 보고서 등 원본 문서. 사이트는 content/works/*.md 와 img/ 만 사용하므로
# _src 는 배포에 불필요하고, 공개 시 내부 정보가 노출될 수 있어 제외.
content/works/_src/

# ── Claude 실행용 개인 런처(로컬 전용) ──
PF.bat
